generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model Story {
  id       Int    @id @default(autoincrement())
  name     String
  avatar   String
  position Int
}

model Post {
  id        Int      @id @default(autoincrement())
  userName  String
  userAvatar String
  image     String
  caption   String
  location  String?
  likes     Int
  comments  Int
  createdAt DateTime @default(now())
}

model Suggestion {
  id     Int    @id @default(autoincrement())
  name   String
  avatar String
  reason String
}
